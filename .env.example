# ── API Server ──────────────────────────────────────────
# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Required: Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/deepseek_chat

# Port the Express API listens on (default: 8080)
PORT=8080

# Optional: shown in OpenRouter dashboard
APP_URL=https://your-domain.com

# ── Chat App (frontend) ──────────────────────────────────
# Optional: set this if your API is on a different domain (e.g. Railway)
# Leave empty if serving frontend and API from the same server
VITE_API_URL=https://your-api.railway.app
